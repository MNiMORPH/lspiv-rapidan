configfile: "../config/config.yaml"

RAW_DIR    = config["raw_dir"]
STAB_DIR   = config["stabilized_dir"]
CAM_DIR    = config["camera_config_dir"]
RESULTS    = config["results_dir"]
EXT        = config["video_extension"]
ORTHOPHOTO = config.get("orthophoto", "")

GEO_METHOD = config.get("georeference_method", "sift")

SAMPLES, = glob_wildcards(f"{RAW_DIR}/{{sample}}.{EXT}")


rule all:
    input:
        expand(f"{RESULTS}/{{sample}}/PIVquiverFrame.png", sample=SAMPLES)


rule stabilize:
    input:
        video=f"{RAW_DIR}/{{sample}}.{EXT}"
    output:
        video=f"{STAB_DIR}/{{sample}}.mp4"
    shell:
        "lspiv-stabilize --input {input.video} --output {output.video}"


def georeference_inputs(wildcards):
    inputs = {"video": f"{STAB_DIR}/{wildcards.sample}.mp4"}
    if GEO_METHOD == "sift":
        inputs["orthophoto"] = ORTHOPHOTO
    return inputs

rule georeference:
    input: unpack(georeference_inputs)
    output:
        camera_config=CAM_DIR + "/{sample}.json"
    params:
        debug_image = RESULTS + "/{sample}/georeference_debug.png",
    run:
        if GEO_METHOD == "sift":
            geo  = config["georeference"]
            farg = (f"--frame {geo['frame_number']}"
                    if geo.get("frame_number") is not None else "")
            shell(
                f"lspiv-georeference"
                f"  --video            {{input.video}}"
                f"  --orthophoto       {{input.orthophoto}}"
                f"  --output           {{output.camera_config}}"
                f"  {farg}"
                f"  --n-gcps           {geo['n_gcps']}"
                f"  --max-ortho-pixels {geo['max_ortho_pixels']}"
                f"  --debug-image      {{params.debug_image}}"
            )
        elif GEO_METHOD == "lab":
            lab = config.get("lab", {})
            warg = f"--width  {lab['width_m']}"  if "width_m"  in lab else ""
            harg = f"--height {lab['height_m']}" if "height_m" in lab else ""
            carg = f"--corners {lab['corners']}" if "corners"  in lab else ""
            shell(
                f"lspiv-lab-config"
                f"  --video  {{input.video}}"
                f"  --output {{output.camera_config}}"
                f"  {warg} {harg} {carg}"
            )
        else:
            raise ValueError(f"Unknown georeference_method: '{GEO_METHOD}'. Use 'sift' or 'lab'.")


rule piv:
    input:
        video         = STAB_DIR + "/{sample}.mp4",
        camera_config = CAM_DIR  + "/{sample}.json"
    output:
        frame      = RESULTS + "/{sample}/Frame.png",
        piv_figure = RESULTS + "/{sample}/PIVquiverFrame.png"
    params:
        start_frame = config["piv"]["start_frame"],
        end_frame   = config["piv"].get("end_frame") or "",
        h_a         = config["piv"]["h_a"],
        engine      = config["piv"]["engine"],
        output_dir  = RESULTS + "/{sample}",
    shell:
        """
        lspiv-piv \
            --video         {input.video} \
            --camera-config {input.camera_config} \
            --output-dir    {params.output_dir} \
            --start-frame   {params.start_frame} \
            --h-a           {params.h_a} \
            --piv-engine    {params.engine} \
            $([ -n "{params.end_frame}" ] && echo "--end-frame {params.end_frame}")
        """
